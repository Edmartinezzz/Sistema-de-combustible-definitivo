# Environment Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=minerales_laguaira
DB_USER=postgres
DB_PASSWORD=your_password_here
DATABASE_URL=postgres://postgres:password@host:port/database?sslmode=require

# Supabase Configuration
SUPABASE_URL=your-project-url.supabase.co
SUPABASE_KEY=your-service-role-key-or-anon-key
SUPABASE_BUCKET=comprobantes

# JWT Configuration
JWT_SECRET=change-this-to-a-very-long-random-secret-key-in-production
JWT_EXPIRATION=24h

# File Upload Configuration
UPLOAD_DIR=./uploads/comprobantes
MAX_FILE_SIZE=5242880

# Email Configuration (Optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=sistema@laguaira.gob.ve
EMAIL_PASS=your_email_password
EMAIL_FROM=Sistema de Minerales <sistema@laguaira.gob.ve>

# Application URL
BASE_URL=http://localhost:3000

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
